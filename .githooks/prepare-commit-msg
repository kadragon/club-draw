#!/bin/sh
# club-draw prepare-commit-msg: auto SemVer bump from commit [TYPE].
#   [FEAT] → minor, any other [TYPE] → patch, major bump stays manual.
# Skips merge/squash/amend and messages without a [TYPE] tag.
# Bypass: git commit --no-verify
set -e

MSG_FILE="$1"
SRC="$2"

# Only bump on a fresh message; skip merge, squash, and amend (SRC=commit).
case "$SRC" in
  merge | squash | commit) exit 0 ;;
esac

# Subject = first non-comment, non-blank line.
SUBJECT=$(grep -v '^#' "$MSG_FILE" | sed '/^[[:space:]]*$/d' | head -n1)

# Require a leading [TYPE] tag; otherwise leave the version untouched.
TYPE=$(printf '%s' "$SUBJECT" | sed -n 's/^\[\([A-Z]*\)\].*/\1/p')
[ -n "$TYPE" ] || exit 0

PKG="package.json"
CUR=$(sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([0-9]*\.[0-9]*\.[0-9]*\)".*/\1/p' "$PKG" | head -n1)
[ -n "$CUR" ] || exit 0

MAJOR=${CUR%%.*}
REST=${CUR#*.}
MINOR=${REST%%.*}
PATCH=${REST#*.}

if [ "$TYPE" = "FEAT" ]; then
  MINOR=$((MINOR + 1))
  PATCH=0
else
  PATCH=$((PATCH + 1))
fi
NEW="$MAJOR.$MINOR.$PATCH"

# Rewrite only the first top-level "version" line, preserving indentation/comma.
awk -v new="$NEW" '
  !done && /"version"[[:space:]]*:/ {
    sub(/"version"[[:space:]]*:[[:space:]]*"[0-9]+\.[0-9]+\.[0-9]+"/, "\"version\": \"" new "\"")
    done = 1
  }
  { print }
' "$PKG" >"$PKG.tmp" && mv "$PKG.tmp" "$PKG"

git add "$PKG"
echo "[prepare-commit-msg] version $CUR → $NEW ($TYPE)"
